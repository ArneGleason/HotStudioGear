---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map(post => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
---

<Layout title={`${post.data.title} | Hot Studio Gear`}>
	<div class="container blog-container">
		<article class="card-parchment blog-article">
			<header style="margin-bottom: 2rem; border-bottom: 2px solid var(--color-outline-variant); padding-bottom: 1.5rem;">
				<h1 class="blog-title">{post.data.title}</h1>
				<div style="font-family: var(--font-label); color: var(--color-surface-variant); font-size: 1.1rem; text-transform: uppercase;">By {post.data.author}</div>
			</header>
			
			{post.data.image && (
				<img 
					src={`${base}/${post.data.image.startsWith('/') ? post.data.image.slice(1) : post.data.image}`} 
					alt={post.data.title} 
					class="blog-hero-image"
				/>
			)}

			<!-- The readable content mapping -->
			<div class="blog-content">
				<Content />
			</div>
		</article>
	</div>
</Layout>

<style is:global>
	.blog-container { padding-top: 3rem; padding-bottom: 3rem; max-width: 800px; margin: 0 auto; }
	.blog-article { padding: 3rem; border-radius: 8px; overflow: hidden; }
	.blog-title { color: var(--color-surface-container-lowest); font-size: 3rem; margin-bottom: 0.5rem; line-height: 1.1; }
	.blog-hero-image { width: 100%; border-radius: 4px; box-shadow: 0 10px 20px rgba(0,0,0,0.5); margin-bottom: 3rem; border: 4px solid var(--color-outline-variant); }
	
	.blog-content {
		font-size: 1.15rem;
		line-height: 1.8;
		color: var(--color-surface-container-lowest);
	}
	.blog-content h2 {
		color: var(--color-surface-container-lowest);
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		font-size: 2rem;
		font-family: var(--font-headline);
		border-bottom: 1px solid rgba(0,0,0,0.1);
		padding-bottom: 0.5rem;
	}
	.blog-content h3 {
		color: var(--color-surface-variant);
		margin-top: 2rem;
		font-size: 1.5rem;
		font-family: var(--font-headline);
	}
	.blog-content p {
		margin-bottom: 1.5rem;
	}
	.blog-content img {
		max-width: 100%;
		border-radius: 4px;
		margin: 2rem 0;
		border: 2px solid var(--color-outline-variant);
		box-shadow: 0 5px 15px rgba(0,0,0,0.3);
	}
	.blog-content blockquote {
		border-left: 6px solid var(--color-primary-container);
		background: rgba(0,0,0,0.05);
		margin: 2rem 0;
		padding: 1.5rem;
		font-family: var(--font-headline);
		font-size: 1.5rem;
		font-style: italic;
		color: var(--color-surface-container-lowest);
	}
	.blog-content strong {
		font-weight: 700;
	}
	.blog-content ul {
		margin-bottom: 1.5rem;
		padding-left: 1.5rem;
	}
	.blog-content li {
		margin-bottom: 0.5rem;
	}

	/* Global Mobile Responsive Logic for Articles */
	@media (max-width: 768px) {
		.blog-container { padding-top: 0 !important; padding-bottom: 2rem !important; padding-left: 0; padding-right: 0; margin-top: 0; }
		.blog-article { padding: 1.5rem 1rem; border-radius: 0; border: none; }
		.blog-title { font-size: 2.2rem; line-height: 1.2; }
		.blog-content { font-size: 1.1rem; }
		
		/* Expand images fully bleeding edge-to-edge */
		.blog-hero-image,
		.blog-content img {
			width: calc(100% + 2rem);
			max-width: none;
			margin-left: -1rem;
			margin-right: -1rem;
			border-radius: 0;
			border-left: none;
			border-right: none;
			margin-top: 1.5rem;
			margin-bottom: 1.5rem;
		}
		
		.blog-content h2 { font-size: 1.6rem; }
		.blog-content blockquote {
			font-size: 1.25rem;
			padding: 1rem;
			margin-left: -1rem;
			margin-right: -1rem;
			border-radius: 0;
		}
	}
</style>
