---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map(post => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
---

<Layout title={`${post.data.title} | Hot Studio Gear`}>
	<div class="container" style="padding-top: 3rem; padding-bottom: 3rem; max-width: 800px;">
		<article class="card-parchment" style="padding: 3rem; border-radius: 8px;">
			<header style="margin-bottom: 2rem; border-bottom: 2px solid var(--color-outline-variant); padding-bottom: 1.5rem;">
				<h1 style="color: var(--color-surface-container-lowest); font-size: 3rem; margin-bottom: 0.5rem; line-height: 1.1;">{post.data.title}</h1>
				<div style="font-family: var(--font-label); color: var(--color-surface-variant); font-size: 1.1rem; text-transform: uppercase;">By {post.data.author}</div>
			</header>
			
			{post.data.image && (
				<img 
					src={`${base}/${post.data.image.startsWith('/') ? post.data.image.slice(1) : post.data.image}`} 
					alt={post.data.title} 
					style="width: 100%; border-radius: 4px; box-shadow: 0 10px 20px rgba(0,0,0,0.5); margin-bottom: 3rem; border: 4px solid var(--color-outline-variant);"
				/>
			)}

			<!-- The readable content mapping -->
			<div class="blog-content">
				<Content />
			</div>
		</article>
	</div>
</Layout>

<style is:global>
	.blog-content {
		font-size: 1.15rem;
		line-height: 1.8;
		color: var(--color-surface-container-lowest);
	}
	.blog-content h2 {
		color: var(--color-surface-container-lowest);
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		font-size: 2rem;
		font-family: var(--font-headline);
		border-bottom: 1px solid rgba(0,0,0,0.1);
		padding-bottom: 0.5rem;
	}
	.blog-content h3 {
		color: var(--color-surface-variant);
		margin-top: 2rem;
		font-size: 1.5rem;
		font-family: var(--font-headline);
	}
	.blog-content p {
		margin-bottom: 1.5rem;
	}
	.blog-content img {
		max-width: 100%;
		border-radius: 4px;
		margin: 2rem 0;
		border: 2px solid var(--color-outline-variant);
		box-shadow: 0 5px 15px rgba(0,0,0,0.3);
	}
	.blog-content blockquote {
		border-left: 6px solid var(--color-primary-container);
		background: rgba(0,0,0,0.05);
		margin: 2rem 0;
		padding: 1.5rem;
		font-family: var(--font-headline);
		font-size: 1.5rem;
		font-style: italic;
		color: var(--color-surface-container-lowest);
	}
	.blog-content strong {
		font-weight: 700;
	}
	.blog-content ul {
		margin-bottom: 1.5rem;
		padding-left: 1.5rem;
	}
	.blog-content li {
		margin-bottom: 0.5rem;
	}
</style>
