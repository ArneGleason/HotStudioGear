---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const acquisitions = await getCollection('acquisitions');

// Helper to resolve image paths out of the collection data (frontmatter vs json structure)
const resolveImg = (imgPath) => {
	if (!imgPath) return '';
	const base = import.meta.env.BASE_URL;
	const cleanBase = base === '/' ? '' : (base.endsWith('/') ? base.slice(0, -1) : base);
	return cleanBase + (imgPath.startsWith('/') ? imgPath : '/' + imgPath);
};
---

<Layout>
	<div class="acquisitions-header">
		<h1>HOT <span>ACQUISITIONS</span></h1>
		<p class="subtitle">Rare gear, improbable provenance, and infrastructure for the almost legendary.</p>
		<p class="intro-copy">
			Not every piece of gear deserves a second life. Some do. Some absolutely do. And some arrive carrying enough technical merit, unresolved psychic charge, and questionable backstory that Gary feels duty-bound to place them before the serious public. Hot Acquisitions is where rare components, vintage oddities, and spiritually significant machinery are offered to those prepared to own them responsibly.
		</p>
	</div>

	<div class="acquisitions-grid">
		{acquisitions.map((item) => {
			const data = item.data;
			return (
				<div class="acq-card" data-details={JSON.stringify(data)}>
					<div class="acq-card-image" style={`background-image: url('${resolveImg(data.primary_image)}')`}>
                        {data.badges && data.badges[0] && (
                            <span class="acq-badge">{data.badges[0]}</span>
                        )}
                    </div>
					<div class="acq-card-content">
						<div class="acq-category">{data.era} • {data.category}</div>
						<h2>{data.item_name}</h2>
						<p class="acq-short">{data.short_description}</p>
						<p class="acq-teaser"><strong>PROVENANCE:</strong> {data.provenance.split('. ')[0] + '.'}</p>
						<button class="acq-open-btn">{data.price_or_offer_label}</button>
					</div>
				</div>
			)
		})}
	</div>

    <div class="acquisitions-footer">
        <h3>Have a piece worthy of Hot Acquisitions?</h3>
        <p>If your equipment carries technical merit, visible dignity, and at least one story Gary can responsibly inflate, <a href="#">get in touch</a>.</p>
    </div>

	<!-- Detail Modal overlay -->
	<dialog id="acq-modal" class="acq-modal">
		<div class="acq-modal-closer"></div>
		<div class="acq-modal-content">
			<button class="acq-modal-close-btn">&times;</button>
			<div class="acq-modal-grid">
				<div class="acq-modal-images">
					<img id="modal-img-primary" src="" alt="Primary Gear Image" />
					<img id="modal-img-secondary" src="" alt="Secondary Gear Detail" />
				</div>
				<div class="acq-modal-info">
					<div class="acq-category" id="modal-meta"></div>
					<h2 id="modal-title"></h2>
                    <div id="modal-badges" class="modal-badges-container"></div>
                    
					<div class="modal-section">
						<h3>Technical Overview</h3>
						<p id="modal-tech"></p>
					</div>
                    
					<div class="modal-section">
						<h3>Condition & Quirks</h3>
						<p><strong>Condition:</strong> <span id="modal-condition"></span></p>
						<p><strong>Known Flaw:</strong> <span id="modal-defect"></span></p>
                        <div class="gary-spin-box">
                            <strong>Gary's Take:</strong> <span id="modal-spin"></span>
                        </div>
					</div>

					<div class="modal-section">
						<h3>Provenance</h3>
						<p id="modal-provenance"></p>
					</div>

                    <div class="gary-remarks-callout">
                        <span class="quote-mark">“</span>
                        <p id="modal-remarks"></p>
                    </div>

					<button class="hero-button" id="modal-cta-btn" style="width: 100%; margin-top: 2rem;">Make an Offer</button>
				</div>
			</div>
		</div>
	</dialog>

	<style>
		.acquisitions-header {
			text-align: center;
			margin: 4rem auto;
			max-width: 800px;
            padding: 0 1rem;
		}
		.acquisitions-header h1 {
			font-family: var(--font-display);
			font-size: 3rem;
			color: #fff;
			margin-bottom: 0.5rem;
		}
		.acquisitions-header h1 span {
			color: var(--color-primary-container);
		}
		.subtitle {
			font-family: var(--font-label);
			font-size: 1.25rem;
			font-weight: bold;
			text-transform: uppercase;
			color: #C0B283; /* Antique brassy tone */
			margin-bottom: 1.5rem;
			letter-spacing: 1px;
		}
		.intro-copy {
			font-size: 1.1rem;
			line-height: 1.6;
			color: #e0e0e0;
		}

		.acquisitions-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
			gap: 2rem;
			margin-bottom: 5rem;
            padding: 0 1rem;
		}

		.acq-card {
			background: var(--color-surface-container-low);
			border: 1px solid var(--color-outline-variant);
			border-radius: 4px;
			overflow: hidden;
			display: flex;
			flex-direction: column;
			transition: transform 0.2s, box-shadow 0.2s;
			cursor: pointer;
		}
		.acq-card:hover {
			transform: translateY(-4px);
			box-shadow: 0 10px 20px rgba(0,0,0,0.5);
			border-color: #C0B283;
		}

		.acq-card-image {
			height: 240px;
			background-size: cover;
			background-position: center;
			background-color: #1a1a1a;
            position: relative;
            border-bottom: 2px solid #C0B283;
		}
        
        .acq-badge {
            position: absolute;
            top: 1rem;
            left: 1rem;
            background: #fff;
            color: #000;
            font-size: 0.75rem;
            font-weight: bold;
            text-transform: uppercase;
            padding: 0.3rem 0.6rem;
            box-shadow: 2px 2px 0px rgba(0,0,0,1);
            font-family: var(--font-label);
        }

		.acq-card-content {
			padding: 1.5rem;
			display: flex;
			flex-direction: column;
			flex-grow: 1;
		}

		.acq-category {
			font-size: 0.8rem;
			text-transform: uppercase;
			color: #C0B283;
			font-family: var(--font-label);
			font-weight: bold;
			margin-bottom: 0.5rem;
            letter-spacing: 1px;
		}

		.acq-card-content h2 {
			font-size: 1.5rem;
			margin-top: 0;
			margin-bottom: 1rem;
			color: #fff;
            font-family: var(--font-display);
		}

		.acq-short {
			font-size: 0.95rem;
			color: #ccc;
			margin-bottom: 1rem;
			flex-grow: 1;
		}
        
        .acq-teaser {
            font-size: 0.9rem;
            color: #999;
            font-style: italic;
            margin-bottom: 1.5rem;
            border-left: 2px solid #555;
            padding-left: 0.75rem;
        }

		.acq-open-btn {
			background: transparent;
			border: 1px solid #fff;
			color: #fff;
			padding: 0.75rem;
			font-family: var(--font-label);
			font-weight: bold;
			text-transform: uppercase;
			cursor: pointer;
			transition: all 0.2s;
		}
		.acq-card:hover .acq-open-btn {
			background: #fff;
			color: #000;
		}

        .acquisitions-footer {
            background: var(--color-surface-container);
            padding: 4rem 2rem;
            text-align: center;
            border-top: 1px solid var(--color-outline-variant);
            margin-bottom: 4rem;
        }
        .acquisitions-footer h3 {
            font-family: var(--font-display);
            font-size: 2rem;
            color: #C0B283;
            margin-bottom: 1rem;
        }

		/* Modal Styles */
		.acq-modal {
			padding: 0;
			border: none;
			background: transparent;
			max-width: 100vw;
			max-height: 100vh;
			width: 100%;
			height: 100%;
		}
		.acq-modal::backdrop {
			background: rgba(0, 0, 0, 0.85);
			backdrop-filter: blur(5px);
		}
		.acq-modal-closer {
			position: absolute;
			top: 0; left: 0; width: 100%; height: 100%;
			cursor: pointer;
		}
		.acq-modal-content {
			position: absolute;
			top: 50%; left: 50%;
			transform: translate(-50%, -50%);
			background: var(--color-surface-container-low);
			width: 90%;
			max-width: 1100px;
			max-height: 90vh;
			overflow-y: auto;
			border: 1px solid var(--color-outline-variant);
            border-top: 4px solid #C0B283;
			box-shadow: 0 25px 50px rgba(0,0,0,0.8);
			z-index: 10;
		}
		.acq-modal-close-btn {
			position: absolute;
			top: 1rem;
			right: 1rem;
			background: transparent;
			border: none;
			color: #fff;
			font-size: 2rem;
			cursor: pointer;
			z-index: 20;
		}
		.acq-modal-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
		}
		@media (max-width: 900px) {
			.acq-modal-grid {
				grid-template-columns: 1fr;
			}
		}

		.acq-modal-images img {
			width: 100%;
			display: block;
			object-fit: cover;
		}
        #modal-img-primary {
            height: 400px;
            border-bottom: 1px solid var(--color-outline-variant);
        }
        #modal-img-secondary {
            height: 300px;
        }

		.acq-modal-info {
			padding: 3rem;
		}
        @media (max-width: 900px) {
            .acq-modal-info { padding: 1.5rem; }
            #modal-img-primary { height: 300px; }
            #modal-img-secondary { height: 200px; }
        }

		.acq-modal-info h2 {
			font-size: 2.5rem;
			margin-top: 0;
			margin-bottom: 1rem;
			color: #fff;
            font-family: var(--font-display);
            line-height: 1.1;
		}

        .modal-badges-container {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-bottom: 2rem;
        }
        .modal-badges-container span {
            background: #fff;
            color: #000;
            font-size: 0.75rem;
            font-weight: bold;
            text-transform: uppercase;
            padding: 0.3rem 0.6rem;
            font-family: var(--font-label);
        }

		.modal-section {
			margin-bottom: 2rem;
		}
		.modal-section h3 {
			font-family: var(--font-label);
			color: #C0B283;
			font-size: 1rem;
			text-transform: uppercase;
			border-bottom: 1px solid #444;
			padding-bottom: 0.5rem;
			margin-bottom: 1rem;
            letter-spacing: 1px;
		}
		.modal-section p {
			font-size: 1rem;
			line-height: 1.6;
			color: #ccc;
			margin-bottom: 0.75rem;
		}

        .gary-spin-box {
            background: rgba(192, 178, 131, 0.1);
            border-left: 3px solid #C0B283;
            padding: 1rem;
            margin-top: 1rem;
            font-size: 0.95rem;
            color: #eee;
        }

        .gary-remarks-callout {
            position: relative;
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 1px dotted #666;
        }
        .quote-mark {
            position: absolute;
            top: -1rem;
            left: 50%;
            transform: translateX(-50%);
            font-family: serif;
            font-size: 4rem;
            color: #C0B283;
            line-height: 1;
            background: var(--color-surface-container-low);
            padding: 0 1rem;
        }
        .gary-remarks-callout p {
            text-align: center;
            font-family: var(--font-display);
            font-size: 1.5rem;
            color: #fff;
            font-style: italic;
        }

        .hero-button {
			background: #fff;
            color: #000;
			border: 2px solid #000;
			box-shadow: inset 0 0 10px rgba(255,255,255,0.2), 0 4px 6px rgba(0,0,0,0.5);
			padding: 1rem;
			font-family: var(--font-label);
			font-weight: bold;
			font-size: 1.1rem;
			cursor: pointer;
			text-transform: uppercase;
		}
        .hero-button:hover {
            background: #e0e0e0;
        }
	</style>

	<script>
		// Client-side script for the modal
		const cards = document.querySelectorAll('.acq-card');
		const modal = document.getElementById('acq-modal');
		const closeBtn = document.querySelector('.acq-modal-close-btn');
		const closerOverlay = document.querySelector('.acq-modal-closer');

        // Helper string resolution inside client JS because import.meta.env isn't reactive here the same way without escaping
        // But we already pre-resolved image paths on the server side in the template? 
        // No, the data object stringified won't have the cleanly resolved base path unless we do it here.
        const base = document.baseURI || '/';
        const cleanBase = base === '/' ? '' : (base.endsWith('/') ? base.slice(0, -1) : base);
        const getImg = (p) => {
            if(!p) return '';
            return cleanBase + (p.startsWith('/') ? p : '/' + p);
        };

		cards.forEach(card => {
			card.addEventListener('click', () => {
				const data = JSON.parse(card.getAttribute('data-details'));
				
				// Populate modal
				document.getElementById('modal-img-primary').src = getImg(data.primary_image);
				document.getElementById('modal-img-secondary').src = getImg(data.secondary_image);
                document.getElementById('modal-img-secondary').style.display = data.secondary_image ? 'block' : 'none';
				
				document.getElementById('modal-meta').textContent = `${data.era} • ${data.category}`;
				document.getElementById('modal-title').textContent = data.item_name;
				
				const badgesContainer = document.getElementById('modal-badges');
				badgesContainer.innerHTML = '';
				if (data.badges) {
					data.badges.forEach(b => {
						const span = document.createElement('span');
						span.textContent = b;
						badgesContainer.appendChild(span);
					});
				}

				document.getElementById('modal-tech').textContent = data.technical_details;
				document.getElementById('modal-condition').textContent = data.condition;
				document.getElementById('modal-defect').textContent = data.humorous_defect;
				document.getElementById('modal-spin').textContent = data.gary_defect_spin;
				document.getElementById('modal-provenance').textContent = data.provenance;
				document.getElementById('modal-remarks').textContent = data.gary_remarks;
				
				document.getElementById('modal-cta-btn').textContent = data.price_or_offer_label || 'Make an Offer';

				modal.showModal();
			});
		});

		const closeModal = () => modal.close();
		closeBtn.addEventListener('click', closeModal);
		closerOverlay.addEventListener('click', closeModal);
	</script>
</Layout>
