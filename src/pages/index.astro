---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allGear = await getCollection('gear');
const allBlog = await getCollection('blog');
const base = import.meta.env.BASE_URL;
---

<Layout>
	<style>
		.hero-title {
			font-size: clamp(2rem, 5vw, 2.5rem);
			color: var(--color-surface-container-lowest);
			font-family: var(--font-display);
			line-height: 1.2;
		}
		.hero-title span {
			font-size: clamp(2.5rem, 8vw, 3.5rem);
			color: var(--color-primary-container);
		}
		.hero-buttons {
			display: flex;
			gap: 2rem;
			justify-content: center;
			align-items: center;
			margin-bottom: 2rem;
		}
		.hero-button {
			border: 2px solid #000;
			box-shadow: inset 0 0 10px rgba(255,255,255,0.2), 0 4px 6px rgba(0,0,0,0.5);
			padding: 1.25rem 2.5rem;
			font-family: var(--font-label);
			font-weight: bold;
			font-size: 1.25rem;
			cursor: pointer;
			text-transform: uppercase;
			width: auto;
		}
		.gary-banner-content {
			position: relative;
			z-index: 10;
			max-width: 50%;
		}
		.gary-speech-bubble {
			position: absolute;
			bottom: 2rem;
			left: 2rem;
		}
		.featured-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
			gap: 1.5rem;
			margin-bottom: 4rem;
		}
		.sub-panels-grid {
			display: grid;
			grid-template-columns: 2fr 1fr;
			gap: 2rem;
			align-items: start;
		}
		
		@media (max-width: 768px) {
			.hero-buttons {
				flex-direction: column;
				gap: 1rem;
			}
			.hero-button {
				width: 100%;
			}
			.gary-banner-content {
				max-width: 100%;
			}
			.gary-speech-bubble {
				display: none; /* Hide relative positioned complex element on mobile to avoid overflow */
			}
			.sub-panels-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
	<div class="container" style="padding-top: 3rem; padding-bottom: 3rem;">
		
		<!-- Hero Section -->
		<section class="card-parchment" style="margin: 2rem auto; max-width: 1000px; text-align: center; padding: 2.5rem; position: relative;">
			<!-- Rivet details -->
			<div style="position: absolute; top: 15px; left: 15px; width: 12px; height: 12px; background: #666; border-radius: 50%; box-shadow: inset -2px -2px 4px rgba(0,0,0,0.8);"></div>
			<div style="position: absolute; top: 15px; right: 15px; width: 12px; height: 12px; background: #666; border-radius: 50%; box-shadow: inset -2px -2px 4px rgba(0,0,0,0.8);"></div>
			<div style="position: absolute; bottom: 15px; left: 15px; width: 12px; height: 12px; background: #666; border-radius: 50%; box-shadow: inset -2px -2px 4px rgba(0,0,0,0.8);"></div>
			<div style="position: absolute; bottom: 15px; right: 15px; width: 12px; height: 12px; background: #666; border-radius: 50%; box-shadow: inset -2px -2px 4px rgba(0,0,0,0.8);"></div>
			
			<h2 class="hero-title">The Internet's Premier Source for<br/><span>Dubious Studio Essentials</span></h2>
			
			<p style="font-size: 1.15rem; max-width: 800px; margin: 1.5rem auto 2.5rem auto; color: var(--color-on-surface-variant); font-family: var(--font-body); font-weight: 500;">
				Obscure audio cable ends, synth repair parts, elderly playback devices, and strange electronic relics for the true connoisseur.
			</p>
			
			<div class="hero-buttons">
				<button class="hero-button" style="background: linear-gradient(180deg, #b43d13, #6b1d02); color: #fff;">Shop Rare Parts</button>
				<button class="hero-button" style="background: linear-gradient(180deg, #e3a936, #805609); color: #000;">Browse Questionable Classics</button>
			</div>
			
			<p style="font-size: 0.9rem; color: var(--color-surface-variant); border-top: 1px solid rgba(0,0,0,0.1); padding-top: 1rem; margin-bottom: 0;">
				Trusted by basement producers, retired broadcast technicians, and men who still say "warmth" with a straight face.
			</p>
		</section>

		<!-- Gary's Huge Ad Banner -->
		<section style={`background-image: url('${base}/images/gary-banner.png'); background-size: cover; background-position: center top; border: 4px solid var(--color-outline-variant); margin-bottom: 3rem; padding: 3rem; position: relative; border-radius: 4px; box-shadow: inset 0 0 100px rgba(0,0,0,0.8); min-height: 450px; overflow: hidden;`}>
			<!-- Dark overlay tint to make text readable -->
			<div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(90deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0) 100%); border-radius: 4px;"></div>
			
			<div class="gary-banner-content">
				<h2 style="font-size: 3.5rem; text-transform: uppercase; color: var(--color-primary-container); text-shadow: 2px 2px 8px rgba(0,0,0,0.9); margin-bottom: 0.5rem; line-height: 1;">Turn Your Life Around!</h2>
				<p style="font-size: 1.5rem; color: #ffffff; text-shadow: 1px 1px 4px rgba(0,0,0,0.9); margin-bottom: 1.5rem; font-family: var(--font-headline);">
					Let me reveal the secrets of a "glorious lifestyle" for only <strong>$10,000</strong> and a <em style="font-style: italic;">plane ticket to Rome!</em>
				</p>
				
				<button style="background: linear-gradient(180deg, #b41340, #510017); border: 2px solid #ffb800; color: #ffffff; padding: 1rem 2rem; font-size: 1.5rem; font-family: var(--font-label); text-transform: uppercase; font-weight: bold; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.8); margin-bottom: 1rem;">Begin The Journey</button>
				
				<p style="font-family: var(--font-label); font-weight: bold; font-size: 1.25rem; color: #ffffff; text-shadow: 1px 1px 4px rgba(0,0,0,0.9); margin-bottom: 0;">
					<span style="color: var(--color-primary-container);">+1-999-HOT-GARY</span><br/>
					<small style="font-size: 0.8rem; opacity: 0.8; font-weight: normal;">$1,000 USD Requires non-refundable deposit.</small>
				</p>
			</div>

			<!-- Speech bubble -->

			
			<!-- Limited Spots badge -->
			<div style="position: absolute; bottom: 2rem; right: 2rem; background: radial-gradient(circle, #ffb800 0%, #7c5800 100%); color: #000; padding: 1.5rem; border-radius: 50%; width: 140px; height: 140px; display: flex; align-items: center; justify-content: center; text-align: center; font-family: var(--font-label); font-weight: bold; font-size: 1.2rem; box-shadow: 0 10px 20px rgba(0,0,0,0.8); border: 2px dashed #000; z-index: 10; transform: rotate(-15deg);">
				LIMITED<br/>SPOTS<br/>LEFT!
			</div>
		</section>

		<!-- Featured Categories Header -->
		<div style="text-align: center; margin: 3rem 0 1.5rem 0; position: relative;">
			<div style="position: absolute; top: 50%; left: 0; right: 0; height: 4px; background: double var(--color-outline-variant); z-index: 1;"></div>
			<div style="position: absolute; top: 52%; left: 0; right: 0; height: 1px; background: var(--color-surface-variant); z-index: 1;"></div>
			<h3 style="display: inline-block; background: var(--color-background); padding: 0 1.5rem; font-family: var(--font-display); font-size: 2.2rem; color: var(--color-surface-container-lowest); position: relative; z-index: 2;">Featured Categories</h3>
		</div>
		
		<!-- Featured Categories Grid -->
		<div class="featured-grid">
			
			<!-- Cat 1 -->
			<div class="card-parchment" style="padding: 1rem; text-align: center;">
				<h4 style="font-family: var(--font-display); font-size: 1.2rem; color: var(--color-surface-container-lowest); min-height: 3rem;">Hard-to-Find<br/>Cable Ends</h4>
				<img src={`${base}/images/cat-cables.png`} alt="Cable Ends" style="width: 100%; aspect-ratio: 1; object-fit: cover; border: 2px solid var(--color-outline-variant); border-radius: 2px; margin: 0.5rem 0 1rem 0;" />
				<p style="font-size: 0.85rem; color: var(--color-surface-variant); text-align: left; margin:0; line-height: 1.3;">Gold-plated adapters, for <em>inconvenient</em> problems. 3 consecutive 15 ohms or "phase grinders".</p>
			</div>
			
			<!-- Cat 2 -->
			<div class="card-parchment" style="padding: 1rem; text-align: center;">
				<h4 style="font-family: var(--font-display); font-size: 1.2rem; color: var(--color-surface-container-lowest); min-height: 3rem;">Synth Repair<br/>Parts</h4>
				<img src={`${base}/images/cat-synth.png`} alt="Synth Parts" style="width: 100%; aspect-ratio: 1; object-fit: cover; border: 2px solid var(--color-outline-variant); border-radius: 2px; margin: 0.5rem 0 1rem 0;" />
				<p style="font-size: 0.85rem; color: var(--color-surface-variant); text-align: left; margin:0; line-height: 1.3;">Replacement sliders, mystery knobs, belt kits, display bulbs, "almost compatible" power supplies.</p>
			</div>
			
			<!-- Cat 3 -->
			<div class="card-parchment" style="padding: 1rem; text-align: center;">
				<h4 style="font-family: var(--font-display); font-size: 1.2rem; color: var(--color-surface-container-lowest); min-height: 3rem;">Tape Decks &<br/>Legacy Oddities</h4>
				<img src={`${base}/images/cat-tape.png`} alt="Tape Decks" style="width: 100%; aspect-ratio: 1; object-fit: cover; border: 2px solid var(--color-outline-variant); border-radius: 2px; margin: 0.5rem 0 1rem 0;" />
				<p style="font-size: 0.85rem; color: var(--color-surface-variant); text-align: left; margin:0; line-height: 1.3;">Cassette multitracks, record-to-reel accessories, and a MiniDisc shelf.</p>
			</div>
			
			<!-- Cat 4 -->
			<div class="card-parchment" style="padding: 1rem; text-align: center;">
				<h4 style="font-family: var(--font-display); font-size: 1.2rem; color: var(--color-surface-container-lowest); min-height: 3rem;">Educational<br/>Electronic Relics</h4>
				<img src={`${base}/images/cat-relics.png`} alt="Plastic Relics" style="width: 100%; aspect-ratio: 1; object-fit: cover; border: 2px solid var(--color-outline-variant); border-radius: 2px; margin: 0.5rem 0 1rem 0;" />
				<p style="font-size: 0.85rem; color: var(--color-surface-variant); text-align: left; margin:0; line-height: 1.3;">Strange plastic teaching machines from 1984. Best enjoyed only in the emotional sense.</p>
			</div>
			
		</div>

		<!-- Sub-panels (Asymmetrical layout concept) -->
		<div class="sub-panels-grid">
			
			<!-- Editorials/Articles Area (Driven by Gear Content Collection) -->
			<section>
				<h3 style="color: var(--color-primary); font-family: var(--font-label); text-transform: uppercase;">Latest Acquisitions</h3>
				
				{allGear.map(item => (
					<div class="card-parchment" style="margin-top: 1.5rem; min-height: 250px;">
						<div class="bezel" style="margin-bottom: 1rem;">
							<span style="background-color: var(--color-primary-container); color: var(--color-on-primary); padding: 0.25rem 0.5rem; font-family: var(--font-label); font-weight: bold; font-size: 0.85rem; border-radius: 4px;">{item.data.isGarySpecial ? "GARY'S STASH" : "NEW LISTING"}</span>
						</div>
						
						<h4 style="font-size: 2rem; margin-bottom: 0.5rem; color: var(--color-surface-container-lowest); font-family: var(--font-display);">{item.data.title}</h4>
						
						{item.data.image && <img src={`${base}/${item.data.image.startsWith('/') ? item.data.image.slice(1) : item.data.image}`} alt={item.data.title} style="width: 100%; object-fit: cover; border-radius: 4px; margin-bottom: 1rem; border: 2px solid var(--color-outline-variant);" />}

						<p style="color: var(--color-secondary-fixed-variant); font-weight: bold; margin-bottom: 1rem; border-bottom: 2px solid rgba(0,0,0,0.1); padding-bottom: 0.5rem;">
							Condition: {item.data.condition} <br/>
							{item.data.price && <span>Price: ${item.data.price}</span>}
						</p>

						<div style="color: var(--color-surface-variant); margin-bottom: 1.5rem; font-size: 1.1rem; line-height: 1.5;">
							{item.body && item.body.substring(0, 150)}...
						</div>
						
						<button class="btn-secondary" style="position: absolute; bottom: 1.5rem; right: 1.5rem;">Haggle With Us</button>
					</div>
				))}

			</section>

			<!-- Gary's Promotional Area (Driven by Blog Content Collection) -->
			<section class="glass-modal" style="border: 1px solid rgba(255,184,0,0.2);">
				<h3 style="color: var(--color-secondary); font-family: var(--font-headline); font-size: 1.8rem; margin-bottom: 1.5rem;">Gary's Ramblings</h3>
				
				{allBlog.map(post => (
					<div style="margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-outline-variant);">
						<a href={`${base}/blog/${post.id}/`} style="text-decoration: none; display: block;">
							{post.data.image && <img src={`${base}/${post.data.image.startsWith('/') ? post.data.image.slice(1) : post.data.image}`} alt={post.data.title} style="width: 100%; object-fit: cover; border-radius: 4px; margin-bottom: 0.5rem;" />}
							<h4 style="color: var(--color-primary); margin-bottom: 0.25rem;">{post.data.title}</h4>
						</a>
						<p style="font-size: 0.85rem; color: var(--color-tertiary-container); margin-bottom: 0.75rem; font-family: var(--font-label);">By {post.data.author}</p>
						
						<!-- Display snippet of blog post -->
						<div style="font-size: 0.95rem; margin-bottom: 1.5rem; color: var(--color-on-background); line-height: 1.4;">
							{post.body && post.body.substring(0, 100)}...
						</div>
						<a href={`${base}/blog/${post.id}/`} class="btn-primary" style="display: block; text-align: center; width: 100%; border-radius: 2px; padding: 0.5rem; font-size: 0.85rem; box-sizing: border-box; text-decoration: none;">Read Gary's Thoughts</a>
					</div>
				))}

				<!-- Standard Gary deal box at the bottom -->
				<div style="margin-top: 2rem; background: var(--color-surface-container-highest); padding: 1rem; border-radius: 4px;">
					<h4 style="color: var(--color-secondary-container); font-family: var(--font-label); margin-bottom: 0.5rem;">TODAY'S SPECIAL</h4>
					<p style="font-size: 0.85rem; color: var(--color-on-surface);">I got a guy who knows a guy. Don't ask questions. Buy these tubes before my wife finds out how much I spent.</p>
					<button class="btn-secondary" style="width: 100%; margin-top: 1rem;">Buy Now (No Returns)</button>
				</div>
			</section>

		</div>

	</div>
</Layout>
