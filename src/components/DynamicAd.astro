---
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

interface Props {
  adId?: string;
  selectRandom?: boolean;
}

const { adId, selectRandom = false } = Astro.props;
const allAds = await getCollection('ads');

let ad = null;

if (adId) {
	ad = allAds.find(a => a.id === adId || a.id === adId + '.json');
}

if (!ad) {
	const sortedAds = allAds.sort((a,b) => b.data.priority - a.data.priority);
	if (selectRandom && sortedAds.length > 0) {
		ad = sortedAds[Math.floor(Math.random() * sortedAds.length)];
	} else if (sortedAds.length > 0) {
		// Just take the highest priority
		ad = sortedAds[0];
	}
}

let finalImage = "";
if (ad) {
	const img = ad.data.image || (ad.data.type === 'gary-banner' ? '/images/gary-banner.png' : (ad.data.type === 'ktel' ? '/images/ktel-cable-selector-bg.png' : '/images/toronto_archive.png'));
	const cleanBase = base === '/' ? '' : (base.endsWith('/') ? base.slice(0, -1) : base);
	finalImage = cleanBase + (img.startsWith('/') ? img : '/' + img);
}



---

{ad && ad.data.type === 'gary-banner' && (
	<section class="gary-banner-container-md" style={`background-image: url('${finalImage}'); background-size: cover; background-position: center top; border: 4px solid var(--color-outline-variant); margin-top: 3rem; margin-bottom: 3rem; padding: 3rem; position: relative; border-radius: 4px; box-shadow: inset 0 0 100px rgba(0,0,0,0.8); min-height: 450px; overflow: hidden;`}>
		<div style="position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(90deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0) 100%); border-radius: 4px; z-index: 0;"></div>
		
		<div class="gary-banner-content-md" style="position: relative; z-index: 5;">
			<h2 style="font-size: 3.5rem; text-transform: uppercase; color: var(--color-primary-container); text-shadow: 2px 2px 8px rgba(0,0,0,0.9); margin-bottom: 0.5rem; line-height: 1; border: none; padding: 0;">{ad.data.title}</h2>
			<p style="font-size: 1.5rem; color: #ffffff; text-shadow: 1px 1px 4px rgba(0,0,0,0.9); margin-bottom: 1.5rem; font-family: var(--font-headline);" set:html={ad.data.description}></p>
			
			<button style="background: linear-gradient(180deg, #b41340, #510017); border: 2px solid #ffb800; color: #ffffff; padding: 1rem 2rem; font-size: 1.5rem; font-family: var(--font-label); text-transform: uppercase; font-weight: bold; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.8); margin-bottom: 1rem;" set:html={ad.data.ctaText}></button>
			
			{ad.data.phoneText && (
				<p style="font-family: var(--font-label); font-weight: bold; font-size: 1.25rem; color: #ffffff; text-shadow: 1px 1px 4px rgba(0,0,0,0.9); margin-bottom: 0;">
					<span style="color: var(--color-primary-container);">{ad.data.phoneText}</span><br/>
					<small style="font-size: 0.8rem; opacity: 0.8; font-weight: normal;">{ad.data.finePrint}</small>
				</p>
			)}
		</div>

		{ad.data.badgeText && (
			<div class="gary-banner-badge" style="position: absolute; bottom: 2rem; right: 2rem; background: radial-gradient(circle, #ffb800 0%, #7c5800 100%); color: #000; padding: 1.5rem; border-radius: 50%; width: 140px; height: 140px; display: flex; align-items: center; justify-content: center; text-align: center; font-family: var(--font-label); font-weight: bold; font-size: 1.2rem; box-shadow: 0 10px 20px rgba(0,0,0,0.8); border: 2px dashed #000; z-index: 10; transform: rotate(-15deg);" set:html={ad.data.badgeText}>
			</div>
		)}
	</section>
)}

{ad && ad.data.type === 'toronto' && (
	<div class="toronto-ad-container-md" style="background-color: var(--color-surface-container-highest); border: 2px dashed #eeddcc; padding: 3rem; margin: 3rem 0; text-align: center; color: var(--color-on-surface); border-radius: 4px;">
	  <img src={finalImage} alt={ad.data.title} style="width:100%; max-height: 400px; object-fit: cover; border-radius: 4px; border: 4px solid var(--color-outline-variant); margin-bottom: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.5);" />
	  <h3 style="font-family: var(--font-display); color: var(--color-primary-container); font-size: 2.2rem; margin-bottom: 1rem; line-height: 1.2; border: none; padding: 0;">{ad.data.title}</h3>
	  <p style="font-size: 1.15rem; margin-bottom: 2rem; max-width: 650px; margin-left: auto; margin-right: auto; line-height: 1.6;" set:html={ad.data.description}></p>
	  <button style="background: linear-gradient(180deg, #111, #000); border: 2px solid #555; color: #fff; padding: 1rem 2rem; font-family: monospace; font-size: 1.2rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 0.75rem; box-shadow: 0 4px 10px rgba(0,0,0,0.5);" set:html={ad.data.ctaText}></button>
	</div>
)}

{ad === null && (
	<!-- Fallback for empty ad slot -->
	<div style="border: 1px dotted red; padding: 1rem;">Ad slot failed to render</div>
)}

{ad && ad.data.type === 'essentials' && (
	<div class="essentials-ad-container" style="background-color: #1a1a1a; border: 4px solid #ffcc00; padding: 2.5rem; margin: 3rem 0; text-align: left; color: #fff; box-shadow: inset 0 0 40px rgba(0,0,0,0.8), 6px 6px 0px #ffcc00; display: flex; flex-direction: column; align-items: center; gap: 2rem;">
	  <img src={finalImage} alt={ad.data.title} style="width:100%; max-height: 450px; object-fit: cover; border: 2px solid #555; box-shadow: 0 8px 16px rgba(0,0,0,0.8);" />
	  <div style="width: 100%;">
	    <h3 style="font-family: 'Arial Black', Impact, sans-serif; font-size: 2.4rem; text-transform: uppercase; margin-bottom: 0.5rem; color: #ffcc00; letter-spacing: -1px; line-height: 1;">{ad.data.title}</h3>
	    <p style="font-size: 1.25rem; font-family: 'Courier New', Courier, monospace; margin-bottom: 2rem; color: #ccc;" set:html={ad.data.description}></p>
	    <button style="background: transparent; color: #ffcc00; border: 3px solid #ffcc00; padding: 1rem 2rem; font-family: 'Arial Black', sans-serif; font-size: 1.2rem; cursor: pointer; text-transform: uppercase; transition: all 0.2s;" onmouseover="this.style.background='#ffcc00'; this.style.color='#000';" onmouseout="this.style.background='transparent'; this.style.color='#ffcc00';" set:html={ad.data.ctaText}></button>
	  </div>
	</div>
)}

{ad && ad.data.type === 'upgrade' && (
	<div class="upgrade-ad-container" style="background-color: #f7f3ec; border: 1px solid #dcd3c6; padding: 4rem; margin: 3rem 0; text-align: center; color: #222; box-shadow: 0 20px 40px rgba(0,0,0,0.05); border-radius: 2px;">
	  <h3 style="font-family: Georgia, 'Times New Roman', serif; font-size: 2.2rem; margin-bottom: 1.5rem; color: #111; font-weight: normal; letter-spacing: 0.05em; font-style: italic;">{ad.data.title}</h3>
	  <img src={finalImage} alt={ad.data.title} style="width:80%; max-width: 600px; max-height: 350px; object-fit: cover; margin-bottom: 2rem; border-radius: 2px; filter: contrast(0.9) brightness(1.05);" />
	  <p style="font-size: 1.1rem; line-height: 1.8; margin-bottom: 2.5rem; max-width: 500px; margin-left: auto; margin-right: auto; color: #555; text-align: justify; font-family: 'Helvetica Neue', Arial, sans-serif;" set:html={ad.data.description}></p>
	  <button style="background-color: #111; color: #f7f3ec; border: none; padding: 1.2rem 3rem; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.15em; cursor: pointer; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'" set:html={ad.data.ctaText}></button>
	</div>
)}

{ad && ad.data.type === 'ktel' && (
	<section class="ktel-banner-container-md" style={`background-image: url('${finalImage}'); background-size: cover; background-position: center right; border: 4px solid var(--color-outline-variant); margin-top: 3rem; margin-bottom: 3rem; position: relative; border-radius: 4px; box-shadow: inset 0 0 100px rgba(0,0,0,0.8); min-height: 520px; overflow: hidden;`}>
		
		<div style="position: absolute; top:0; left:0; width:100%; height:35%; background: linear-gradient(180deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0) 100%); z-index: 0;"></div>
		<div style="position: absolute; bottom:0; left:0; width:100%; height:35%; background: linear-gradient(0deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0) 100%); z-index: 0;"></div>

		<div class="ktel-banner-content-md" style="position: relative; z-index: 5; padding: 2.5rem; display: flex; flex-direction: column; justify-content: space-between; height: 100%; box-sizing: border-box; min-height: 520px;">
			<div style="max-width: 650px; display: flex; flex-direction: column; align-items: flex-start;">
				<div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; text-shadow: 2px 2px 4px rgba(0,0,0,1);">
					<svg width="45" height="45" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
						<circle cx="50" cy="50" r="48" fill="#000000" />
						<path d="M40,25 C10,25 10,75 40,75" stroke="#ffffff" stroke-width="12" fill="none" stroke-linecap="round"/>
						<path d="M60,35 C40,40 40,60 60,65" stroke="#ffffff" stroke-width="10" fill="none" stroke-linecap="round"/>
						<path d="M80,45 C70,48 70,52 80,55" stroke="#ffffff" stroke-width="8" fill="none" stroke-linecap="round"/>
					</svg>
					<span style="font-family: 'Arial Black', Impact, sans-serif; font-size: 2.2rem; color: #ffffff; line-height: 1; letter-spacing: 2px;">K-TEL <span style="font-size: 1.25rem; font-family: 'Arial', sans-serif; font-weight: bold; letter-spacing: 1px; color: #ddd;">PRESENTS</span></span>
				</div>
				<h2 style="font-size: 3.8rem; text-transform: uppercase; color: #ffcc00; text-shadow: 3px 3px 6px rgba(0,0,0,1); margin-top: 0; margin-bottom: 0.5rem; line-height: 0.95; border: none; padding: 0; font-family: 'Arial Black', Impact, sans-serif;">{ad.data.title}</h2>
				<p style="font-size: 1.4rem; color: #ffffff; text-shadow: 2px 2px 6px rgba(0,0,0,1); font-family: 'Arial', sans-serif; text-transform: uppercase; letter-spacing: 1px; font-weight: bold; margin-bottom: 0;" set:html={ad.data.description}></p>
			</div>
			
			<div style="margin-top: auto; max-width: 85%; align-self: flex-start; padding-top: 2rem;">
				{ad.data.finePrint && (
					<p style="font-family: 'Arial Black', Impact, sans-serif; font-size: 1.8rem; color: #ffcc00; text-shadow: 3px 3px 6px rgba(0,0,0,1); margin-bottom: 0.25rem; line-height: 1.1;">
						{ad.data.finePrint.split('.')[0] + '.'} {ad.data.finePrint.split('.')[1] + '.'}
					</p>
				)}
				{ad.data.finePrint && ad.data.finePrint.split('.')[2] && (
					<p style="font-family: 'Arial', sans-serif; font-size: 1.15rem; color: #ffffff; text-shadow: 2px 2px 6px rgba(0,0,0,1); margin-bottom: 0; font-weight: bold;">
						{ad.data.finePrint.split('.').slice(2).join('.').trim()}
					</p>
				)}
			</div>
		</div>

		{ad.data.ctaText && (
			<div class="ktel-banner-badge" style="position: absolute; bottom: 1.5rem; right: 1.5rem; background: #ffcc00; color: #000; padding: 1.75rem; width: 150px; height: 150px; display: flex; align-items: center; justify-content: center; text-align: center; font-family: 'Arial Black', Impact, sans-serif; font-weight: bold; font-size: 1.4rem; box-shadow: -4px 4px 0px #000, 0 10px 20px rgba(0,0,0,0.9); z-index: 10; transform: rotate(-8deg); text-transform: uppercase;">
				<span style="line-height: 1.15;" set:html={ad.data.ctaText}></span>
			</div>
		)}
	</section>
)}

<style>
	.gary-banner-content-md { max-width: 60%; }
	@media (max-width: 768px) {
		.gary-banner-container-md {
			padding: 1.5rem !important;
			margin-left: -1rem !important;
			margin-right: -1rem !important;
			width: calc(100% + 2rem) !important;
			border-radius: 0 !important;
			border-left: none !important;
			border-right: none !important;
			min-height: 350px !important;
			background-position: left center !important;
		}
		.gary-banner-content-md { max-width: 100%; text-align: center; }
		.gary-banner-content-md h2 { font-size: 2.2rem !important; }
		.gary-banner-content-md p { font-size: 1.1rem !important; }
		.gary-banner-badge { transform: scale(0.6) rotate(-15deg) !important; bottom: 0.5rem !important; right: 0.5rem !important; }
		
		.toronto-ad-container-md {
			padding: 1.5rem !important;
			margin-left: -1rem !important;
			margin-right: -1rem !important;
			width: calc(100% + 2rem) !important;
			border-radius: 0 !important;
			border-left: none !important;
			border-right: none !important;
		}
		.toronto-ad-container-md img { max-height: 250px !important; border-width: 2px !important; margin-bottom: 1rem !important; }
		.toronto-ad-container-md h3 { font-size: 1.6rem !important; }
		.toronto-ad-container-md p { font-size: 1rem !important; margin-bottom: 1rem !important; }
		.toronto-ad-container-md button { font-size: 1rem !important; padding: 0.75rem 1rem !important; }
		
		.ktel-banner-container-md {
			padding: 1.5rem !important;
			margin-left: -1rem !important;
			margin-right: -1rem !important;
			width: calc(100% + 2rem) !important;
			border-radius: 0 !important;
			border-left: none !important;
			border-right: none !important;
			min-height: 480px !important;
			background-position: right center !important;
		}
		.ktel-banner-content-md { max-width: 100%; padding: 1.5rem !important; text-align: left; justify-content: flex-start !important; }
		.ktel-banner-content-md h2 { font-size: 2.2rem !important; }
		.ktel-banner-content-md p { font-size: 1.1rem !important; }
		.ktel-banner-badge { transform: scale(0.7) rotate(-5deg) !important; bottom: 0.5rem !important; right: 0.5rem !important; }
	}
</style>
