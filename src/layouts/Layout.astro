---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "Hot Studio Gear | The Analog Antiquarian" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header style="background-color: var(--color-surface-container-lowest); border-bottom: 4px solid var(--color-outline-variant); margin-bottom: 0;">
			<!-- Top Brand Panel -->
			<div style="background-color: #1a1512; padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #000; position: relative; max-width: 1200px; margin: 0 auto;">
				
				<!-- Left Knobs/Meters -->
				<div style="width: 100px; height: 100px; background: radial-gradient(circle, #333, #000); border-radius: 50%; border: 4px solid #555; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 10px rgba(0,0,0,0.8);">
					<div style="width: 80px; height: 80px; background: #222; border-radius: 50%; border-top: 2px solid #888;"></div>
				</div>
				
				<!-- Center Title & Subtitle -->
				<div style="text-align: center; flex: 1;">
					<h1 style="margin:0; font-size: 3.5rem; color: #ffb800; font-family: var(--font-display); text-shadow: 0 0 15px rgba(255,184,0,0.6); font-style: italic;">HotStudioGear.com</h1>
					<p style="font-family: var(--font-label); color: #ccc; margin: 0.5rem 0 0 0; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85rem;">Because your masterpiece is one obsolete adapter away.</p>
				</div>
				
				<!-- Right VU Meter -->
				<div style="width: 120px; height: 80px; background: #e0d5a6; border: 4px solid #444; border-radius: 4px; position: relative; box-shadow: inset 0 0 10px rgba(0,0,0,0.5);">
					<div style="position: absolute; bottom: 0; left: 50%; width: 2px; height: 60px; background: #c00; transform-origin: bottom center; transform: rotate(15deg);"></div>
					<div style="position: absolute; top: 10px; right: 10px; font-family: monospace; font-size: 0.6rem; color: #333; font-weight: bold;">VU</div>
					<div style="position: absolute; top: 10px; left: 10px; font-family: monospace; font-size: 0.4rem; color: #333;">HOTSTUDIO</div>
				</div>
			</div>
			
			<!-- Cramped Nav Bar -->
			<nav style="background: linear-gradient(180deg, #3a2e22, #1c150e); border-bottom: 2px solid #111; border-top: 2px solid #554131; padding: 0.75rem;">
				<ul style="list-style: none; margin: 0; padding: 0; display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap;">
					<li><a href="/" style="color: #ccc; text-decoration: none; font-family: var(--font-label); text-transform: uppercase; font-size: 0.85rem; font-weight: bold; letter-spacing: 0.05em;"><span style="color:var(--color-primary-container)">★</span> ABOUT US</a></li>
					<li><a href="#" style="color: #ccc; text-decoration: none; font-family: var(--font-label); text-transform: uppercase; font-size: 0.85rem; font-weight: bold; letter-spacing: 0.05em;">• REPAIR PARTS</a></li>
					<li><a href="#" style="color: #ccc; text-decoration: none; font-family: var(--font-label); text-transform: uppercase; font-size: 0.85rem; font-weight: bold; letter-spacing: 0.05em;">• CABLE ENDS</a></li>
					<li><a href="#" style="color: #ccc; text-decoration: none; font-family: var(--font-label); text-transform: uppercase; font-size: 0.85rem; font-weight: bold; letter-spacing: 0.05em;">• TAPE & LEGACY</a></li>
					<li><a href="#" style="color: #ccc; text-decoration: none; font-family: var(--font-label); text-transform: uppercase; font-size: 0.85rem; font-weight: bold; letter-spacing: 0.05em;">• CONTACT GARY</a></li>
				</ul>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="surface-lowest" style="padding: 2rem; text-align: center; margin-top: 4rem; color: var(--color-outline);">
			<p style="font-family: var(--font-label);">© 1974 - {new Date().getFullYear()} Hot Studio Gear. "Gary" says buy more tubes.</p>
		</footer>
	</body>
</html>
